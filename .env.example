# ---------------------------------------------------------------------------
# Magic Ops scan bridge — configuration
# Copy to ".env" and fill in. Never commit the real .env.
# ---------------------------------------------------------------------------

# Admin base URL (the VPS). No trailing slash.
ADMIN_URL=https://admin.example.com

# Shared secret. MUST equal scan.bridgeKey in the admin's .env.
SCAN_KEY=

# Identify this bridge (free text, unique per store PC).
BRIDGE_ID=store71-pc
BRIDGE_LABEL=Store 71 front desk
# Optional: tie jobs/heartbeats to a store id from the admin "stores" table.
STORE_ID=

# How the bridge gets the scan:
#   escl  - scan over the network via eSCL/AirScan (recommended for networked scanners)
#   naps2 - shell out to NAPS2 Console (use for USB scanners; requires NAPS2 installed)
#   mock  - generate a sample PDF instead of scanning (dry-run / pipeline test)
SCAN_MODE=escl

# --- Scanner (eSCL) ---
# The scanner's IP. From the device panel: Settings > Network > TCP/IP.
SCANNER_IP=192.168.0.204
# Optional mDNS service name to auto-discover the scanner if SCANNER_IP changes
# (the panel shows Boot Method = Auto/DHCP, so the IP can move). Requires the
# optional "bonjour-service" dependency. Leave blank to disable discovery.
SCANNER_MDNS_NAME=

# --- NAPS2 fallback (only used when SCAN_MODE=naps2) ---
NAPS2_PATH=C:\\Program Files\\NAPS2\\NAPS2.Console.exe
# Easiest: configure a NAPS2 profile once in the NAPS2 GUI, put its name here.
NAPS2_PROFILE=

# --- Timing ---
POLL_INTERVAL_MS=4000
HEARTBEAT_INTERVAL_MS=30000
# Max seconds to wait for the whole scan before giving up.
SCAN_TIMEOUT_MS=120000
