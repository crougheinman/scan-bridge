# ---------------------------------------------------------------------------
# Magic Ops scan bridge — configuration
# Copy to ".env" and fill in. Never commit the real .env.
# ---------------------------------------------------------------------------

# Admin base URL (the VPS). No trailing slash.
ADMIN_URL=https://admin.example.com

# This store's bridge key. Generate it in the admin under the store's details
# (Stores > [store] > Scan bridge > Generate bridge key) and paste it here.
# It identifies this bridge AND its store — the admin derives both from the key.
SCAN_KEY=

# Identify this bridge (the admin shows the suggested value, e.g. store71-bridge).
BRIDGE_ID=store71-bridge
BRIDGE_LABEL=Store 71 front desk
# The store id this bridge belongs to (shown in the admin alongside the key).
STORE_ID=

# How the bridge gets the scan:
#   escl  - scan over the network via eSCL/AirScan (recommended for networked scanners)
#   naps2 - shell out to NAPS2 Console (use for USB scanners; requires NAPS2 installed)
#   mock  - generate a sample PDF instead of scanning (dry-run / pipeline test)
SCAN_MODE=escl

# --- Scanner (eSCL) ---
# Default/fallback scanner IP. Each job is routed to a specific scanner the admin
# picks (registered under the store's details), and that IP overrides this per
# job. This value is only the fallback when a job carries no target scanner.
SCANNER_IP=192.168.0.204
# Optional mDNS service name to auto-discover the scanner if SCANNER_IP changes
# (the panel shows Boot Method = Auto/DHCP, so the IP can move). Requires the
# optional "bonjour-service" dependency. Leave blank to disable discovery.
SCANNER_MDNS_NAME=

# --- NAPS2 fallback (only used when SCAN_MODE=naps2) ---
NAPS2_PATH=C:\\Program Files\\NAPS2\\NAPS2.Console.exe
# Easiest: configure a NAPS2 profile once in the NAPS2 GUI, put its name here.
NAPS2_PROFILE=

# --- Timing ---
POLL_INTERVAL_MS=4000
HEARTBEAT_INTERVAL_MS=30000
# Max time to wait for the whole scan before giving up (ms).
SCAN_TIMEOUT_MS=120000

# --- Deep-sleep tolerance (eSCL) ---
# Some scanners sleep hard: they answer ping but stall on the first HTTP call.
# The bridge wakes them and retries instead of reporting "unreachable".
ESCL_PROBE_TIMEOUT_MS=10000
ESCL_WAKE_RETRIES=3
ESCL_RETRY_DELAY_MS=2000
